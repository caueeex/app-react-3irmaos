# Copie para backend/.env e preencha com seus valores (Supabase: Project Settings → API).

JWT_SECRET=defina-uma-chave-secreta-longa-e-unica

SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-chave-anon-ou-service-role

PORT=3000

# Opcional: leitura RFID pelo hardware (header X-Api-Key). Sem isso, POST /api/rfid/leitura responde 503.
# RFID_API_KEY=
