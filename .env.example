# Raiz do projeto Expo — copie para `.env` e reinicie o bundler (`npx expo start --clear`).

# URL do backend (celular na rede / hotspot)
# EXPO_PUBLIC_API_URL=http://192.168.0.10:3000

# Opcional: cadastro sem campo «Perfil» na tela — envia sempre esse id_perfil (ex.: 2 = Operador).
# Se não definir, o app volta a listar perfis com GET /api/perfil.
# EXPO_PUBLIC_REGISTER_PERFIL_ID=2
